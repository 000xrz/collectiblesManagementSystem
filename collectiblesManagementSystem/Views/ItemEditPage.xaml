<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="collectiblesManagementSystem.Views.ItemEditPage"
             Title="Edycja przedmiotu">
    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="15">
            <Grid WidthRequest="170" HeightRequest="170" HorizontalOptions="Center">
                <Frame Padding="0" CornerRadius="10" BorderColor="#D3D3D3" HasShadow="False" BackgroundColor="#F5F5F5">
                    <Image x:Name="ItemImage" HeightRequest="170" WidthRequest="170" Aspect="AspectFit" />
                </Frame>
                <Label x:Name="NoImageLabel"
                       Text="Brak zdjęcia"
                       FontSize="14"
                       TextColor="#95A5A6"
                       HorizontalTextAlignment="Center"
                       VerticalTextAlignment="Center" />
            </Grid>
            <Button Text="Wybierz zdjęcie..." Clicked="OnSelectImageClicked" BackgroundColor="#2980B9" TextColor="White" CornerRadius="8" />
            
            <Label Text="Nazwa przedmiotu:" FontAttributes="Bold" />
            <Entry x:Name="NameEntry" Placeholder="np. Wiedźmin 3, Lego Star Wars..." />

            <Label Text="Cena (zł):" FontAttributes="Bold" />
            <Entry x:Name="PriceEntry" Keyboard="Numeric" Placeholder="np. 150.50" />

            <Label Text="Ilość (szt.):" FontAttributes="Bold" />
            <Entry x:Name="QuantityEntry" Keyboard="Numeric" Placeholder="np. 1" />

            <Label Text="Status:" FontAttributes="Bold" />
            <Picker x:Name="StatusPicker" SelectedIndex="0">
                <Picker.Items>
                    <x:String>Nowy</x:String>
                    <x:String>Używany</x:String>
                    <x:String>Na sprzedaż</x:String>
                    <x:String>Sprzedany</x:String>
                    <x:String>Chcę kupić</x:String>
                </Picker.Items>
            </Picker>

            <Label x:Name="RatingLabel" Text="Ocena: 5/10" FontAttributes="Bold" />
            <Slider x:Name="RatingSlider" Minimum="1" Maximum="10" Value="5" ValueChanged="OnRatingChanged" />

            <Label Text="Dodatkowy komentarz:" FontAttributes="Bold" />
            <Editor x:Name="CommentEditor" HeightRequest="80" Placeholder="Wpisz tu swoje uwagi..." />
            
            <VerticalStackLayout x:Name="CustomColumnsContainer" Spacing="10" />

            <Button Text="Zapisz" Clicked="OnSaveClicked" BackgroundColor="#27AE60" TextColor="White" CornerRadius="8" FontAttributes="Bold" Margin="0,20,0,0"/>
            <Button x:Name="DeleteButton" Text="Usuń przedmiot" Clicked="OnDeleteClicked" BackgroundColor="#C0392B" TextColor="White" CornerRadius="8" IsVisible="False" />
            
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>